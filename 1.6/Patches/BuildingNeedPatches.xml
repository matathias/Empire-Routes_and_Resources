<?xml version="1.0" encoding="utf-8" ?>
<Patch>

	<!-- ============================================================ -->
	<!-- Helper: ensure modExtensions node exists on a BuildingFCDef  -->
	<!-- (most base mod buildings don't have one)                     -->
	<!-- ============================================================ -->

	<!-- Smithy — needs Mining (ore/metal) -->
	<Operation Class="PatchOperationSequence">
		<success>Always</success>
		<operations>
			<li Class="PatchOperationTest">
				<xpath>/Defs/FactionColonies.BuildingFCDef[defName="Smithy"]/modExtensions</xpath>
				<success>Invert</success>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>/Defs/FactionColonies.BuildingFCDef[defName="Smithy"]</xpath>
				<value><modExtensions/></value>
			</li>
		</operations>
	</Operation>
	<Operation Class="PatchOperationAdd">
		<xpath>/Defs/FactionColonies.BuildingFCDef[defName="Smithy"]/modExtensions</xpath>
		<value>
			<li Class="FactionColonies.SupplyChain.BuildingNeedExtension">
				<inputs>
					<li><resource>RTD_Mining</resource><amount>0.5</amount></li>
				</inputs>
				<penalties>
					<li><stat>happinessLostBase</stat><penaltyPerUnit>2.0</penaltyPerUnit><label>material shortage</label></li>
				</penalties>
			</li>
		</value>
	</Operation>

